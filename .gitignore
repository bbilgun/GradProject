# ─────────────────────────────────────────────────────────────────
# Project-specific runtime artifacts (do NOT commit)
# ─────────────────────────────────────────────────────────────────
# SQLite database
app.db
backend/app.db
*.sqlite
*.sqlite3

# RAG caches (regenerated on startup)
pdf_cache.json
web_cache.json
backend/pdf_cache.json
backend/web_cache.json

# Stray pip-output artifacts (from misquoted shell redirects)
backend/=*
=*

# Generated static assets / uploads
backend/static/uploads/

# ─────────────────────────────────────────────────────────────────
# Environment / secrets
# ─────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
backend/.env

